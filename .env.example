# ───────────────────────────────────────────────────────────────────────────
# Painel Financeiro — MODELO de variáveis de ambiente (profiles dev / prod).
#
# Como os profiles funcionam (Next.js):
#   • dev  -> "npm run dev"          (NODE_ENV=development)
#   • prod -> "npm run build/start"  (NODE_ENV=production)
#
# Onde colocar:
#   • Local/dev:  copie para ".env.local" e preencha (NUNCA versione o .env.local).
#   • Produção:   cadastre cada variável no servidor / plataforma.
#   • Config central: src/lib/config.ts (fonte única de verdade).
#
# Legenda: [PÚBLICA] vai pro navegador • [SECRETA]/[PESSOAL] só no servidor.
# ───────────────────────────────────────────────────────────────────────────

# Profile (opcional; por padrão segue o NODE_ENV)
APP_ENV=development                                             # development | production

# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────
#   dev -> localhost   |   prod -> banco de produção (VM / Cloud SQL)
DATABASE_URL=postgresql://app_financeiro:SENHA@HOST:5432/painel_joao_marcos

# ── Autmais (Open Finance) ────────────────────────────────────────────────
AUTMAIS_AUTH_BASE=https://api3.autmais.com.br/v1
AUTMAIS_MONGO_BASE=https://apimongo.autmais.com.br/v1
AUTMAIS_USER=usuario_autmais                                   # [SECRETA]
AUTMAIS_PASS=senha_autmais                                     # [SECRETA]
AUTMAIS_TENANT=seu_tenant_autmais

# ── Painel ────────────────────────────────────────────────────────────────
# Documento (CPF/CNPJ, só dígitos) da empresa-alvo na Autmais.
PAINEL_EMPRESA_DOC=00000000000                                 # [PESSOAL] CPF/CNPJ do cliente
# Nome da marca usado no servidor (textos/IA).
PAINEL_BRAND_NAME=Painel Financeiro
# Wordmark exibido na interface (client-side).
NEXT_PUBLIC_BRAND_NAME=Painel Financeiro                       # [PÚBLICA]
DEMO_MODE=0                                                    # 1 = libera demo SEM login (use só com dados fictícios)
NEXT_PUBLIC_DEMO_MODE=0                                        # 1 = esconde botões que exigem credencial (Sincronizar)
CRON_SECRET=defina_uma_string_aleatoria_longa                  # [SECRETA]

# ── SSO Google Workspace ──────────────────────────────────────────────────
#   prod -> URL do serviço SSO   |   dev -> deixe VAZIO p/ dispensar login no localhost
SSO_BASE_URL=

# ── IA (Claude / Anthropic) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui                     # [SECRETA]
